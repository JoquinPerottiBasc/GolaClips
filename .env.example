# ── Gemini (Google AI) ──────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single line (minified)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=golaclips-clips

# ── OpenAI (optional, for Spanish translation) ───────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty for local SQLite. On Railway, set this to the PostgreSQL URL.
# Railway provides this automatically when you add a PostgreSQL plugin.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
